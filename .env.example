# Infra env — consumed by docker-compose.yml (Hydra + Kratos) and rendered into
# config/kratos.yml via envsubst at container start. The app backends read their
# own monorepo/.env (KRATOS_PUBLIC_URL, AUTH_BASE_URL, app secrets, etc.), NOT
# this file.

# App URLs
AUTH_URL=https://auth-local.idnest.cloud
CORS_ALLOWED_ORIGINS=https://*.idnest.cloud,https://*.daybook.cloud,https://console-local.taskme.sh

# Hydra. The setup scripts derive the database user, password, name and schema
# from this DSN instead of duplicating them as separate env variables.
HYDRA_DSN=postgres://hydrau:replace-with-hydra-password@host.docker.internal:5432/hydra?sslmode=disable
HYDRA_URLS_SELF_ISSUER=https://hydra-local.idnest.cloud/
HYDRA_URLS_CONSENT=https://auth-local.idnest.cloud/consent
HYDRA_URLS_LOGIN=https://auth-local.idnest.cloud/login
HYDRA_URLS_LOGOUT=https://auth-local.idnest.cloud/logout
HYDRA_URLS_POST_LOGOUT_REDIRECT=https://admin-local.idnest.cloud/auth/logout
HYDRA_URLS_ERROR=https://auth-local.idnest.cloud/error
HYDRA_SECRETS_SYSTEM=replace-with-a-long-random-secret

# Kratos. Database provisioning is likewise derived from this DSN.
KRATOS_DSN=postgres://kratosu:replace-with-kratos-password@host.docker.internal:5432/kratos?sslmode=disable
KRATOS_SERVE_PUBLIC_BASE_URL=https://kratos-local.idnest.cloud
KRATOS_ADMIN_URL=http://localhost:4434
KRATOS_URLS_LOGOUT=https://hydra-local.idnest.cloud/oauth2/sessions/logout
KRATOS_COOKIES_DOMAIN=.idnest.cloud
KRATOS_LOG_LEVEL=info
KRATOS_CSRF_COOKIE_SECRET=replace-with-a-long-random-secret
KRATOS_CIPHER_SECRET=replace-with-32-character-secret

# Google OIDC
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Optional Apple OIDC for Kratos. Leave all blank to omit the provider locally.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_PRIVATE_KEY_ID=
APPLE_PRIVATE_KEY=
