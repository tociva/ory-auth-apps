# Shared Ory endpoints (server-side only — never exposed to the browser)
HYDRA_ADMIN_URL=http://localhost:4445
KRATOS_ADMIN_URL=http://localhost:4434
KRATOS_PUBLIC_URL=http://localhost:4433

# Backends
AUTH_BACKEND_PORT=4000
ADMIN_BACKEND_PORT=4100
CORS_ALLOWED_ORIGINS=https://auth.daybook.cloud,https://admin.idnest.dev,https://app-dev.daybook.cloud

# auth-backend's own public origin. Used to build the Kratos `return_to` URL
# (/login/return) after a successful login. No trailing slash. This MUST equal
# the infra `AUTH_URL` origin that appears in Kratos `allowed_return_urls`
# (e.g. https://auth-local.daybook.cloud), otherwise Kratos rejects the return.
AUTH_BASE_URL=http://localhost:4000

# Admin authorization (bootstrap allowlist, comma-separated, lowercased)
ADMIN_BOOTSTRAP_EMAILS=princekfrancis@gmail.com

# The admin frontend loads browser-public config at runtime from its
# `public/config.json` (build-once / deploy-many), not from env vars:
#   - apps/admin-frontend/public/config.json
#
# The auth pages (login / consent / logout / error) are now server-rendered by
# auth-backend — there is no separate frontend build or config.json. Point
# Hydra's URLS_LOGIN / URLS_CONSENT / URLS_LOGOUT / URLS_ERROR and Kratos's
# login `ui_url` at the auth-backend routes (e.g. ${AUTH_BASE_URL}/login).
