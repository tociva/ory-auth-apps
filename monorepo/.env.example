# Shared Ory endpoints. The ADMIN urls are server-side only (never exposed to
# the browser). KRATOS_PUBLIC_URL must be the browser-reachable public Kratos
# host, because auth-backend redirects the browser there and forwards the
# session cookie to it.
HYDRA_ADMIN_URL=http://localhost:4445
KRATOS_ADMIN_URL=http://localhost:4434
KRATOS_PUBLIC_URL=https://kratos-local.idnest.cloud
# Internal Kratos public API base for backend-to-Kratos calls. This skips local
# nginx/TLS so Node does not need to trust the mkcert CA.
KRATOS_INTERNAL_URL=http://localhost:4433

# Browser origins allowed to call admin-backend. Keep this admin-only; public
# app and Ory browser origins are configured separately.
CORS_ALLOWED_ORIGINS=https://*.idnest.cloud,https://*.daybook.cloud,https://console-local.taskme.sh
ADMIN_CORS_ALLOWED_ORIGINS=https://*.idnest.cloud,https://console-local.taskme.sh

# Secret used to sign admin-backend CSRF tokens. Set a long random value in prod.
ADMIN_CSRF_SECRET=replace-with-a-long-random-secret

# Central consent/client-access store used by auth-backend and admin-backend.
AUTHZ_DATABASE_URL=postgres://authzu:replace-with-password@127.0.0.1:5432/authz?sslmode=disable
CONSENT_GATE_MODE=observe
CONSENT_ACTION_SECRET=replace-with-a-long-random-secret
AUTH_BRANDING_MODE=enforce
AUTH_STRICT_UNMAPPED_CLIENTS=false
AUTH_TRANSACTION_TTL_SECONDS=600
AUTH_TRANSACTION_SECRET=replace-with-a-32-byte-or-longer-random-secret
AUTH_AUDIT_HASH_SECRET=replace-with-an-independent-long-random-secret
# HTTPS origins permitted for activated brand images. Root-relative assets on
# auth.idnest.cloud are always accepted. Keep nginx `img-src` in sync when
# adding an origin.
AUTH_ASSET_ALLOWED_ORIGINS=https://assets.idnest.cloud
AUTH_LINK_ALLOWED_ORIGINS=https://idnest.cloud,https://daybook.cloud,https://taskme.sh

# auth-backend's own public origin. Used to build the Kratos `return_to` URL
# (/oauth2/login/complete) after a successful login. No trailing slash. This MUST equal
# the infra `AUTH_URL` origin that appears in Kratos `allowed_return_urls`
# (e.g. https://auth-local.idnest.cloud), otherwise Kratos rejects the return.
AUTH_BASE_URL=https://auth-local.idnest.cloud

# Admin BFF / authorization. When there are no active system administrators,
# the first verified login matching this email allowlist is granted that role.
ADMIN_PUBLIC_ORIGIN=https://admin-local.idnest.cloud
ADMIN_BOOTSTRAP_EMAILS=admin@example.com

# Admin confidential OIDC client. These are server-side only and must match the
# infrastructure client provisioned by bootstrap-local.sh. The client id, scope,
# audience, callback and session TTLs use the shared defaults defined in code.
ADMIN_OIDC_CLIENT_SECRET=replace-with-admin-client-secret
ADMIN_OIDC_AUTHORITY=https://hydra-local.idnest.cloud/
ADMIN_OIDC_REDIRECT_URIS=https://admin-local.idnest.cloud/api/admin/auth/callback,https://console-local.taskme.sh/api/admin/auth/callback
ADMIN_AUTH_POST_LOGOUT_REDIRECT_URIS=https://admin-local.idnest.cloud/auth/logout,https://console-local.taskme.sh/auth/logout

# Browser-public value used when templating admin-frontend config.json.
ADMIN_API_BASE_URL=/api
ADMIN_AUTH_LOGOUT_URL=https://auth-local.idnest.cloud/logout

# Prod swaps the *-local.idnest.cloud hosts for auth.idnest.cloud /
# kratos.idnest.cloud / admin.idnest.cloud, and app-local for app.daybook.cloud.
#
# The admin frontend loads browser-public config at runtime from its
# `public/config.json` (build-once / deploy-many). Authentication pages are a
# separate Angular build under /auth/, while auth-backend owns the trusted
# /oauth2/* and /auth/v1/* orchestration endpoints.
