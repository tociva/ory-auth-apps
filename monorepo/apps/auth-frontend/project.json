{
  "name": "auth-frontend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/auth-frontend/src",
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/auth-frontend",
        "index": "apps/auth-frontend/src/index.html",
        "browser": "apps/auth-frontend/src/main.ts",
        "baseHref": "/auth/",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/auth-frontend/tsconfig.app.json",
        "assets": [
          { "glob": "**/*", "input": "apps/auth-frontend/public", "output": "." }
        ],
        "styles": ["apps/auth-frontend/src/styles.css"],
        "scripts": []
      },
      "configurations": {
        "production": {
          "optimization": true,
          "outputHashing": "all",
          "budgets": [
            { "type": "initial", "maximumWarning": "550kb", "maximumError": "900kb" }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "options": {
        "buildTarget": "auth-frontend:build:development",
        "port": 4502,
        "allowedHosts": ["auth-local.idnest.cloud"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/auth-frontend/tsconfig.app.json --noEmit"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  },
  "tags": ["scope:auth", "type:app"]
}
