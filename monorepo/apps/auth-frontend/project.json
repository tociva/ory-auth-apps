{
  "name": "auth-frontend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/auth-frontend/src",
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/auth-frontend",
        "index": "apps/auth-frontend/src/index.html",
        "browser": "apps/auth-frontend/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/auth-frontend/tsconfig.app.json",
        "assets": [],
        "styles": [
          "apps/auth-frontend/src/styles.css",
          "node_modules/@tailng-ui/theme/index.css",
          "node_modules/@tailng-ui/theme/component-contracts/index.css"
        ],
        "scripts": []
      },
      "configurations": {
        "production": {
          "optimization": true,
          "outputHashing": "all",
          "budgets": [
            { "type": "initial", "maximumWarning": "1mb", "maximumError": "2mb" }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "options": {
        "buildTarget": "auth-frontend:build:development",
        "port": 4200
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/auth-frontend/tsconfig.app.json --noEmit"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  },
  "tags": ["scope:auth", "type:app"]
}
