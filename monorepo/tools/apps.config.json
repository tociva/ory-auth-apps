{
  "$comment": "One entry per product app that consumes auth via its own Hydra OAuth client. `public: true` marks browser SPAs (no client secret) which use token_endpoint_auth_method=none and therefore require PKCE.",
  "apps": [
    {
      "client_id": "daybook-user-client",
      "client_name": "Daybook User Client",
      "client_uri": "https://app.daybook.cloud",
      "policy_uri": "https://app.daybook.cloud/privacy",
      "tos_uri": "https://app.daybook.cloud/terms",
      "contacts": ["support@daybook.cloud"],
      "metadata": {
        "trust_tier": "first_party",
        "consent_version": 1,
        "remember_offline_access": true
      },
      "public": true,
      "scope": "openid profile email offline_access",
      "redirect_uris": [
        "https://app.daybook.cloud/auth/callback",
        "https://app-dev.daybook.cloud/auth/callback",
        "https://app-local.daybook.cloud/auth/callback"
      ],
      "post_logout_redirect_uris": [
        "https://app.daybook.cloud/auth/logout",
        "https://app-dev.daybook.cloud/auth/logout",
        "https://app-local.daybook.cloud/auth/logout"
      ],
      "audience": ["daybook.cloud-users"]
    },
    {
      "client_id": "idnest-admin-client",
      "client_name": "Idnest Admin Console",
      "client_uri": "https://admin.idnest.cloud",
      "policy_uri": "https://admin.idnest.cloud/privacy",
      "tos_uri": "https://admin.idnest.cloud/terms",
      "contacts": ["support@idnest.cloud"],
      "metadata": {
        "trust_tier": "first_party",
        "consent_version": 1,
        "remember_offline_access": false
      },
      "public": false,
      "scope": "openid profile email",
      "redirect_uris": [
        "https://admin-local.idnest.cloud/api/admin/auth/callback",
        "https://admin.idnest.cloud/api/admin/auth/callback"
      ],
      "post_logout_redirect_uris": [
        "https://admin-local.idnest.cloud/auth/logout",
        "https://admin.idnest.cloud/auth/logout"
      ],
      "audience": ["idnest-admin"]
    }
  ]
}
