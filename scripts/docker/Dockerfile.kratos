FROM oryd/kratos:v25.4.0

# Install gettext (provides `envsubst`) for both Alpine or Debian variants
USER root
RUN (apk add --no-cache gettext 2>/dev/null) || \
    (apt-get update && apt-get install -y --no-install-recommends gettext-base && rm -rf /var/lib/apt/lists/*)
COPY scripts/docker/render-kratos-config.sh /usr/local/bin/render-kratos-config.sh
RUN chmod 755 /usr/local/bin/render-kratos-config.sh
